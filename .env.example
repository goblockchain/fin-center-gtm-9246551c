# UseFin — variáveis de ambiente (copie para .env e preencha)
# Só a publishable key vai ao front (protegida por RLS); a service_role NUNCA.
# Segredos reais (service_role / sb_secret_) vão em .env.local, que é ignorado.
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# É ESTA a variável que src/lib/supabase.ts usa. Sem ela, o app não conecta.
# (O antigo VITE_SUPABASE_ANON_KEY foi removido: documentava um nome que o
# código não lia mais, e um ambiente configurado por este arquivo falhava
# todo login com "Invalid API key".)
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
